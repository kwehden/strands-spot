{
  "name": "mcp-toolsmith",
  "description": "Designs MCP tool surfaces with least privilege, safety gates, and structured specifications.",
  "prompt": "file://../prompts/mcp-toolsmith.md",
  "tools": ["read", "write", "glob", "grep", "shell"],
  "allowedTools": ["read", "glob", "grep"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["spec/mcp.md", "mcp/**"]
    },
    "shell": {
      "autoAllowReadonly": true
    }
  },
  "resources": ["file://../steering/**/*.md"],
  "hooks": {
    "preToolUse": [
      {"matcher": "shell", "command": ".kiro/hooks/dangerous-command-blocker.sh"},
      {"matcher": "read", "command": ".kiro/hooks/sensitive-file-protector.sh"},
      {"matcher": "write", "command": ".kiro/hooks/sensitive-file-protector.sh"},
      {"matcher": "shell", "command": ".kiro/hooks/sensitive-file-protector.sh"}
    ],
    "postToolUse": [
      {"matcher": "write", "command": ".kiro/hooks/auto-formatter.sh"},
      {"matcher": "write", "command": ".kiro/hooks/type-checker.sh"}
    ]
  }
}
