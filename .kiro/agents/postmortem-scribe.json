{
  "name": "postmortem-scribe",
  "description": "Writes blameless incident postmortems with root cause analysis and actionable follow-ups.",
  "prompt": "file://../prompts/postmortem-scribe.md",
  "tools": ["read", "write", "glob", "grep"],
  "allowedTools": ["read", "glob", "grep"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["postmortems/**/*.md"]
    }
  },
  "resources": ["file://../steering/**/*.md"],
  "hooks": {
    "preToolUse": [
      {"matcher": "read", "command": ".kiro/hooks/sensitive-file-protector.sh"},
      {"matcher": "write", "command": ".kiro/hooks/sensitive-file-protector.sh"}
    ]
  }
}
