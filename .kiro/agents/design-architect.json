{
  "name": "design-architect",
  "description": "Produces spec/design.md with architecture, interfaces, failure modes, and rollout plan.",
  "prompt": "file://../prompts/design-architect.md",
  "tools": ["read", "write", "glob", "grep", "thinking"],
  "allowedTools": ["read", "glob", "grep", "thinking"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["spec/design.md"]
    }
  },
  "resources": ["file://../steering/**/*.md"],
  "hooks": {
    "preToolUse": [
      {"matcher": "read", "command": ".kiro/hooks/sensitive-file-protector.sh"},
      {"matcher": "write", "command": ".kiro/hooks/sensitive-file-protector.sh"}
    ]
  }
}
