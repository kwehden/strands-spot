{
  "name": "docs-release",
  "description": "Updates documentation, changelog, and release notes with user-facing impact focus.",
  "prompt": "file://../prompts/docs-release.md",
  "tools": ["read", "write", "glob", "grep"],
  "allowedTools": ["read", "glob", "grep"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["README.md", "CHANGELOG.md", "MIGRATIONS.md", "docs/**/*.md", "spec/**/*.md"]
    }
  },
  "resources": ["file://../steering/**/*.md"],
  "hooks": {
    "preToolUse": [
      {"matcher": "read", "command": ".kiro/hooks/sensitive-file-protector.sh"},
      {"matcher": "write", "command": ".kiro/hooks/sensitive-file-protector.sh"}
    ]
  }
}
