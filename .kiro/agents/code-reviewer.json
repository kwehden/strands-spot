{
  "name": "code-reviewer",
  "description": "Performs senior-level read-only review of diffs against specs for correctness, maintainability, and risk.",
  "prompt": "file://../prompts/code-reviewer.md",
  "tools": ["read", "glob", "grep", "shell"],
  "allowedTools": ["read", "glob", "grep"],
  "toolsSettings": {
    "shell": {
      "allowedCommands": ["git diff", "git log", "git status", "git show"],
      "autoAllowReadonly": true
    }
  },
  "resources": ["file://../steering/**/*.md"],
  "hooks": {
    "preToolUse": [
      {"matcher": "shell", "command": ".kiro/hooks/dangerous-command-blocker.sh"},
      {"matcher": "read", "command": ".kiro/hooks/sensitive-file-protector.sh"},
      {"matcher": "shell", "command": ".kiro/hooks/sensitive-file-protector.sh"}
    ]
  }
}
