{
  "name": "task-planner",
  "description": "Converts spec/design.md into spec/tasks.md with atomic tasks and verification steps.",
  "prompt": "file://../prompts/task-planner.md",
  "tools": ["read", "write", "glob", "grep"],
  "allowedTools": ["read", "glob", "grep"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["spec/tasks.md"]
    }
  },
  "resources": ["file://../steering/**/*.md"],
  "hooks": {
    "preToolUse": [
      {"matcher": "read", "command": ".kiro/hooks/sensitive-file-protector.sh"},
      {"matcher": "write", "command": ".kiro/hooks/sensitive-file-protector.sh"}
    ]
  }
}
