{
  "name": "requirements-engineer",
  "description": "Translates spec/context.md into EARS requirements with validation and traceability.",
  "prompt": "file://../prompts/requirements-engineer.md",
  "tools": ["read", "write", "glob", "grep", "thinking"],
  "allowedTools": ["read", "glob", "grep", "thinking"],
  "toolsSettings": {
    "write": {
      "allowedPaths": ["spec/requirements.md"]
    }
  },
  "resources": ["file://../steering/**/*.md"],
  "hooks": {
    "preToolUse": [
      {"matcher": "read", "command": ".kiro/hooks/sensitive-file-protector.sh"},
      {"matcher": "write", "command": ".kiro/hooks/sensitive-file-protector.sh"}
    ]
  }
}
